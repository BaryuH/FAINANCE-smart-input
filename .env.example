# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT_SECONDS=60

# API runtime
AICORE_ENV=production
AICORE_HOST=0.0.0.0
AICORE_PORT=8000
AICORE_RELOAD=false
AICORE_UVICORN_WORKERS=1
AICORE_LOG_LEVEL=INFO
AICORE_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Limits
AICORE_MAX_IMAGE_MB=10
AICORE_MAX_AUDIO_MB=20

# GPU queue
AICORE_GPU_QUEUE_MAXSIZE=64
AICORE_GPU_WORKERS=1
AICORE_REQUEST_TIMEOUT_SEC=120
